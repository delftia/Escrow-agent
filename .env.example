# ─── App ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Telegram ───────────────────────────────────
# Get from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─── OpenAI ─────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# ─── TON ────────────────────────────────────────
# mainnet or testnet
TON_NETWORK=testnet

# API key from https://toncenter.com (optional, for higher rate limits)
TONCENTER_API_KEY=

# 24-word mnemonic of your ESCROW wallet
# IMPORTANT: Create a dedicated wallet, never use your personal wallet
MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24

# Wallet version for escrow operations
WALLET_VERSION=agentic

# Address of the deployed agentic wallet
# Get this by running: npx @ton/mcp@alpha (it will print the address on first run)
AGENTIC_WALLET_ADDRESS=EQyour_agentic_wallet_address_here

# "real": real TON blockchain transactions (escrow wallet is used)
# "demo": payments are simulated (no real transfers, safe for testing)
APP_MODE=real

# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql://trustdeal:trustdeal@localhost:5432/trustdeal

# ─── Redis ──────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
